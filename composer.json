{
    "name": "karelwintersky/arris.php-file-upload",
    "description": "Powerful PHP8 file upload library with validation, conversion, and fluent interface",
    "type": "library",
    "keywords": ["file", "upload", "validation", "image", "conversion"],
    "license": "MIT",
    "authors": [
        {
            "name": "Karel Wintersky",
            "email": "karel.wintersky@yandex.ru"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-fileinfo": "*",
        "ext-gd": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Arris\\Toolkit\\": "sources/"
        },
        "exclude-from-classmap": [
            "/tests/"
        ]
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
